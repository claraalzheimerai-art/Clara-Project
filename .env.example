# Servidor
NODE_ENV=development
PORT=3000
API_VERSION=v1

# CORS
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Microservicio IA
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=60000

# Archivos
UPLOAD_MAX_SIZE_MB=50
UPLOAD_TEMP_DIR=uploads/temp

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# SQL Server
SQLSERVER_URI=Server=localhost,1433;Database=clara_db;User Id=sa;Password=Passw0rd;Encrypt=false;TrustServerCertificate=true

# JWT
JWT_SECRET=clara_jwt_secret_2026_usc_alzheimer
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=clara_refresh_secret_2026_usc_alzheimer
JWT_REFRESH_EXPIRES_IN=7d

